          "fontSize": [{ "value": 11 }],
          "gridlineColor": [{ "solid": { "color": "#F3F4F6" } }]
        }]
      }
    },
    "barChart": {
      "*": {
        "dataPoint": [{
          "defaultColor": [{ "solid": { "color": "#2563EB" } }]
        }],
        "categoryAxis": [{
          "show": [{ "value": true }],
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }],
          "gridlineColor": [{ "solid": { "color": "#F3F4F6" } }]
        }],
        "valueAxis": [{
          "show": [{ "value": true }],
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }],
          "gridlineColor": [{ "solid": { "color": "#F3F4F6" } }]
        }]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [{
          "defaultColor": [{ "solid": { "color": "#2563EB" } }]
        }],
        "categoryAxis": [{
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }],
          "gridlineColor": [{ "solid": { "color": "#F3F4F6" } }]
        }],
        "valueAxis": [{
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }],
          "gridlineColor": [{ "solid": { "color": "#F3F4F6" } }]
        }]
      }
