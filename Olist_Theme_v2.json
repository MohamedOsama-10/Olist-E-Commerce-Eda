      }
    },
    "treemap": {
      "*": {
        "dataPoint": [{
          "defaultColor": [{ "solid": { "color": "#10B981" } }]
        }],
        "labels": [{
          "show": [{ "value": true }],
          "color": [{ "solid": { "color": "#FFFFFF" } }],
          "fontSize": [{ "value": 11 }]
        }]
      }
    },
    "scatterChart": {
      "*": {
        "dataPoint": [{
          "defaultColor": [{ "solid": { "color": "#10B981" } }]
        }],
        "categoryAxis": [{
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }]
        }],
        "valueAxis": [{
          "showTitle": [{ "value": false }],
          "labelColor": [{ "solid": { "color": "#6B7280" } }],
          "fontSize": [{ "value": 11 }]
        }]
      }
